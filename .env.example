# GEMINI_API_KEY: Required for Gemini AI features.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# URL của backend API.
# - Khi dev (npm run dev): Vite dùng giá trị này để proxy /api sang backend.
#   Mặc định: http://localhost:3001
# - Khi build (npm run build): axios sẽ gọi thẳng tới URL này.
#   Ví dụ: https://api.yourdomain.com
VITE_API_URL=http://localhost:3001
